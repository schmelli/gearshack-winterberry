# Supabase Configuration (Feature 040)
# Get these from your Supabase dashboard: https://supabase.com/dashboard/project/_/settings/api
# NEXT_PUBLIC_SUPABASE_URL: Your project URL (e.g., "https://xxxxx.supabase.co")
# NEXT_PUBLIC_SUPABASE_ANON_KEY: Your project anon/public key
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cloudinary Configuration (Feature 038)
# Get these from your Cloudinary dashboard: https://cloudinary.com/console
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME: Your Cloudinary cloud name (e.g., "your-cloud-name")
# NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET: Unsigned upload preset name (create one with unsigned uploads enabled)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# Cloudinary API Configuration (Feature 048 - AI Image Generation)
# Get API Key and Secret from: https://cloudinary.com/console/settings/security
# Required for server-side image storage
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AI Image Generation Configuration (Feature 048)
# Enable/disable AI image generation feature
AI_GENERATION_ENABLED=true

# Vercel AI Gateway API Key (Feature 048)
# Generate at: https://vercel.com/ai-gateway
# Required for AI image generation via Vercel AI SDK
AI_GATEWAY_API_KEY=

# AI Model for Image Generation (Feature 048)
# Supported models:
# - google/gemini-2.5-flash-image (recommended - fast and cost-effective)
# - openai/dall-e-3 (higher quality, more expensive)
# - stability-ai/stable-diffusion-xl (open source alternative)
# Full list: https://vercel.com/ai-gateway/models?q=image
AI_IMAGE_MODEL=google/gemini-2.5-flash-image

# Optional: Service Role Key for RLS bypass operations (Feature 048)
# Get from: https://supabase.com/dashboard/project/_/settings/api
# WARNING: Keep this secret! Only use server-side!
SUPABASE_SERVICE_ROLE_KEY=

# Serper API Key (Image Search)
SERPER_API_KEY=

# GearGraph API Key (Product Data)
GEARGRAPH_API_KEY=

# Google Maps API Key (Feature 041 - Location Autocomplete)
# Get this from Google Cloud Console: https://console.cloud.google.com/
# Enable: Maps JavaScript API, Places API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

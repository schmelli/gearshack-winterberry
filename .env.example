# Supabase Configuration (Feature 040)
# Get these from your Supabase dashboard: https://supabase.com/dashboard/project/_/settings/api
# NEXT_PUBLIC_SUPABASE_URL: Your project URL (e.g., "https://xxxxx.supabase.co")
# NEXT_PUBLIC_SUPABASE_ANON_KEY: Your project anon/public key
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Direct PostgreSQL Connection (Feature 002-mastra-memory-system)
# Get from: Supabase Dashboard > Settings > Database > Connection string (URI)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# REQUIRED for Mastra Memory with semantic recall (pgvector)
DATABASE_URL=

# Cloudinary Configuration (Feature 038)
# Get these from your Cloudinary dashboard: https://cloudinary.com/console
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME: Your Cloudinary cloud name (e.g., "your-cloud-name")
# NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET: Unsigned upload preset name (create one with unsigned uploads enabled)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# Cloudinary API Configuration (Feature 048 - AI Image Generation)
# Get API Key and Secret from: https://cloudinary.com/console/settings/security
# Required for server-side image storage
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AI Image Generation Configuration (Feature 048)
# Enable/disable AI image generation feature
AI_GENERATION_ENABLED=true

# Vercel AI Gateway API Key (Feature 048)
# Generate at: https://vercel.com/ai-gateway
# Required for AI image generation via Vercel AI SDK
AI_GATEWAY_API_KEY=

# AI Model for Image Generation (Feature 048)
# Supported models:
# - google/gemini-2.5-flash-image (recommended - fast and cost-effective)
# - openai/dall-e-3 (higher quality, more expensive)
# - stability-ai/stable-diffusion-xl (open source alternative)
# Full list: https://vercel.com/ai-gateway/models?q=image
AI_IMAGE_MODEL=google/gemini-2.5-flash-image

# Optional: Service Role Key for RLS bypass operations (Feature 048)
# Get from: https://supabase.com/dashboard/project/_/settings/api
# WARNING: Keep this secret! Only use server-side!
SUPABASE_SERVICE_ROLE_KEY=

# Serper API Key (Image Search)
SERPER_API_KEY=

# GearGraph API Key (Product Data)
GEARGRAPH_API_KEY=

# Google Maps API Key (Feature 041 - Location Autocomplete)
# Get this from Google Cloud Console: https://console.cloud.google.com/
# Enable: Maps JavaScript API, Places API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ===================================================================
# Merchant Integration Configuration (Feature 053)
# ===================================================================

# Offer Fee Configuration (configurable pricing)
# Rate (percentage): Default 0.02 = 2% of offer price per offer
NEXT_PUBLIC_OFFER_FEE_RATE=0.02
# Minimum fee per offer: Default €0.50
NEXT_PUBLIC_MIN_OFFER_FEE=0.5
# Maximum fee per offer: Default €5.00
NEXT_PUBLIC_MAX_OFFER_FEE=5.0

# Cron Job Secret (for automated offer expiration)
# Generate a secure random string for production
# Used by /api/cron/expire-offers to validate requests
CRON_SECRET=

# ===================================================================
# AI Assistant Configuration (Feature 050)
# ===================================================================

# AI Chat Assistant (REQUIRED for AI features to work)
# Enable the AI Assistant feature
AI_CHAT_ENABLED=true

# Vercel AI Gateway API Key (REQUIRED)
# Get from: https://vercel.com/ai-gateway
# Used for: All AI chat features, tool calling, orchestration
# Note: This is the SAME key as AI_GATEWAY_API_KEY above (defined twice for clarity)
# If you already set AI_GATEWAY_API_KEY, no need to set this separately

# AI Model for Chat (optional - defaults shown)
AI_CHAT_MODEL=anthropic/claude-sonnet-4.5
AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1/ai

# Direct Anthropic API Key (OPTIONAL - not currently used)
# Future: May be used for advanced features bypassing Vercel AI Gateway
# Get from: https://console.anthropic.com
# ANTHROPIC_API_KEY=

# Web Search Integration (OPTIONAL)
# Enable web search grounding for real-time information
WEB_SEARCH_ENABLED=false
# Get from: https://serper.dev (Google Search API)
SERPER_API_KEY=
# Rate limits (optional - defaults shown)
WEB_SEARCH_DAILY_LIMIT=10
WEB_SEARCH_MONTHLY_LIMIT=100
WEB_SEARCH_CONVERSATION_LIMIT=2

# Testing Configuration (OPTIONAL - for development/testing only)
# WARNING: Disables ALL rate limiting and subscription checks
# Set to 'true' to bypass rate limits during testing
# NEVER enable this in production!
AI_RATE_LIMITING_DISABLED=false
NEXT_PUBLIC_AI_RATE_LIMITING_DISABLED=false

# ===================================================================
# Mastra Eval Configuration (Feature mastra-evals)
# Used by: npm run eval / npm run eval:ci
# ===================================================================

# Fraction of live agent responses to evaluate (0.0-1.0, default: 0.1)
# Production: keep low (e.g. 0.1) to minimise judge model costs
# CI: set to 1.0 via eval:ci script for full coverage
EVAL_SAMPLING_RATE=0.1

# Judge model for LLM-based scorers (faithfulness, hallucination, tool-call accuracy)
# Default: openai/gpt-4o-mini (fast and cost-effective for scoring)
EVAL_JUDGE_MODEL=openai/gpt-4o-mini

# Score thresholds — CI fails if a dataset's aggregate score crosses these
# Faithfulness: minimum acceptable score (higher = better, default: 0.7)
EVAL_THRESHOLD_FAITHFULNESS=0.7
# Hallucination: maximum acceptable score (lower = better, default: 0.3)
EVAL_THRESHOLD_HALLUCINATION=0.3
# Tool-call accuracy: minimum acceptable score (higher = better, default: 0.8)
EVAL_THRESHOLD_TOOL_ACCURACY=0.8

# Enable verbose eval logging (set to '1' to enable, unset for silent)
# Activates [Mastra Evals] log lines from createGearAssistantWithEvals()
MASTRA_DEBUG=

# ===================================================================
# Mastra Agentic Voice AI Configuration (Feature 001-mastra-agentic-voice)
# ===================================================================

# Core Mastra Agent Configuration
# AI Model for Mastra Agent (default: anthropic/claude-sonnet-4-5)
MASTRA_MODEL=anthropic/claude-sonnet-4-5

# Embedding Model for Semantic Recall & Vector Search
# Options:
#   - openai/text-embedding-3-small (1536 dims, default, English-optimized)
#   - cohere/embed-multilingual-v3.0 (1024 dims, true DE/EN parity)
# Switching models requires:
#   1. Running the migration:     npx supabase db push
#   2. Backfilling existing data: EMBEDDING_MODEL=cohere/embed-multilingual-v3.0 npx tsx scripts/reembed-multilingual.ts
#   3. Evaluating DE/EN parity:   npx tsx scripts/eval-multilingual-embeddings.ts
EMBEDDING_MODEL=openai/text-embedding-3-small
# Mastra Studio — Local Development (npx mastra dev / npm run mastra:dev)
# Stub user ID for Studio tool execution. Set to your Supabase user ID so that
# user-scoped tools (analyzeLoadout, inventoryInsights, addToLoadout, etc.) work
# in Agent Chat and Tool Playground. Leave empty to skip user-scoped tools.
# Get your user ID from: Supabase Dashboard > Authentication > Users
# WARNING: Never point DATABASE_URL at a production database when using Studio.
# Format: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx  (Supabase user UUID)
MASTRA_STUDIO_USER_ID=
# Optional: Studio server port (default: 4111)
MASTRA_STUDIO_PORT=4111
# Optional: Embedding model for Studio memory (default: openai/text-embedding-3-small)
AI_EMBEDDING_MODEL=openai/text-embedding-3-small

# Memory & Data Retention
# Days to retain conversation memory in database (default: 90)
# GDPR compliance: Set based on your data retention policy
MASTRA_MEMORY_RETENTION_DAYS=90

# Memory history limit for context (default: 50)
# How many messages to include in conversation context
MASTRA_MEMORY_HISTORY_LIMIT=50

# Token limit for memory-injected context (default: 180000)
# Keeps total memory tokens under Claude Sonnet's 200k context window
# TokenLimiter processor truncates oldest messages first
# MASTRA_TOKEN_LIMIT=180000

# Observational Memory (OM) - Long-context compression
# Enable OM for tool-heavy conversations (default: true)
# Compresses tool results and messages into dense observations (5-40× compression)
OBSERVATIONAL_MEMORY_ENABLED=true

# Model for Observer and Reflector agents (default: google/gemini-2.5-flash)
# Must have large context window (1M+ tokens recommended)
OM_MODEL=google/gemini-2.5-flash

# Token threshold to trigger Observer (default: 20000)
# Lower than default 30k because our tools generate many tokens
OM_MESSAGE_TOKENS=20000

# Token threshold to trigger Reflector (default: 40000)
OM_OBSERVATION_TOKENS=40000

# Logging & Observability
# Log level: 'info' | 'debug' | 'warn' | 'error' (default: 'info')
MASTRA_LOG_LEVEL=info

# Enable Prometheus metrics collection (default: true)
MASTRA_METRICS_ENABLED=true

# Enable distributed tracing with OpenTelemetry (default: true)
MASTRA_TRACING_ENABLED=true

# Voice Features Configuration
# Maximum audio file size in MB (default: 25)
# Used for voice transcription uploads
MASTRA_MAX_AUDIO_SIZE_MB=25

# MCP (Model Context Protocol) Client Configuration
# Transport type: 'stdio' (development) or 'http' (production)
# stdio: Runs MCP server as subprocess
# http: Connects to deployed MCP server
MCP_TRANSPORT=http

# MCP server URL for HTTP transport (production)
# For local development with HTTP transport: http://localhost:8080
# For production: Your deployed MCP server URL
MCP_SERVER_URL=http://localhost:8080

# Tool cache TTL in milliseconds (default: 300000 = 5 minutes)
# How long to cache MCP tool definitions before refreshing
MCP_TOOL_CACHE_TTL_MS=300000

# Tool call timeout in milliseconds (default: 5000 = 5 seconds)
# Maximum time to wait for MCP tool execution
MCP_TOOL_TIMEOUT_MS=5000

# OpenAI API Configuration (for Voice Features)
# Get from: https://platform.openai.com/api-keys
# Required for: Whisper (speech-to-text) and TTS (text-to-speech)
OPENAI_API_KEY=

# Weather API Configuration (for Trip Planner Workflow)
# Get from: https://openweathermap.org/api
# Optional: Only needed if using trip planner feature
OPENWEATHER_API_KEY=

# Admin User IDs (for Metrics Endpoint Access)
# Comma-separated list of user IDs with admin access to /api/mastra/metrics
# SECURITY: Only these users can access Prometheus metrics endpoint
# Example: ADMIN_USER_IDS=uuid1,uuid2,uuid3
ADMIN_USER_IDS=

# ===================================================================
# User Onboarding Configuration
# ===================================================================

# Beta Mode (User Onboarding Feature)
# Controls whether beta-specific onboarding steps are shown
# Set to 'true' to enable beta onboarding features
# If 'false' or not set, beta features will be disabled
NEXT_PUBLIC_IS_BETA=true

# ===================================================================
# URL Import Enhancement Configuration (Feature 054)
# ===================================================================

# Firecrawl API Key (OPTIONAL)
# Get from: https://firecrawl.dev
# Used for: Enhanced web scraping with structured data extraction
# If not set: Falls back to pattern-based URL extraction (still functional)
FIRECRAWL_API_KEY=

# Contributor Hash Salt (REQUIRED for production)
# Used for: Privacy-preserving hashing of contributor identifiers
# Generate a secure random string (32+ characters recommended)
# Example: openssl rand -base64 32
# WARNING: Once set, do not change in production (breaks existing hashes)
CONTRIBUTOR_HASH_SALT=

# Firecrawl Cache TTL (OPTIONAL)
# Days to cache Firecrawl API responses (default: 7)
# Lower = fresher data, higher API usage
# Higher = stale data possible, lower API costs
FIRECRAWL_CACHE_TTL_DAYS=7

# Firecrawl Caching (OPTIONAL)
# Enable/disable caching of Firecrawl responses (default: true)
# Disable for development/debugging if you need fresh data on each request
FIRECRAWL_CACHE_ENABLED=true

# ===================================================================
# eBay Integration Configuration (Feature 054, Feature 057)
# ===================================================================

# eBay Developer Credentials (REQUIRED for eBay price lookups in wishlist)
# Get from: https://developer.ebay.com/my/keys
# Create an Application Key Set (Production or Sandbox)
# Required for: Wishlist price tracking, eBay listing search
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# eBay Environment (OPTIONAL)
# Set to 'sandbox' for development/testing with eBay Sandbox API
# Defaults to 'production' if not set
# EBAY_ENVIRONMENT=production

# GearGraph Price Discovery
# Triggers automatic price discovery when a gear item is created without manufacturer_price.
# NEXT_PUBLIC_ prefix is required because the trigger runs in browser context (Zustand store).
NEXT_PUBLIC_GEARGRAPH_API_URL=https://geargraph.gearshack.app
NEXT_PUBLIC_GEARGRAPH_API_KEY=
